# Configure these as GlassFish JVM system properties or operating-system environment variables.
EZBOOST_ENV=development
EZBOOST_DB_URL=jdbc:derby://localhost:1527/ezboost_db
EZBOOST_DB_USER=app
EZBOOST_DB_PASSWORD=replace-with-a-strong-local-password
EZBOOST_SECURE_COOKIES=false
# Required before Calendarific keys can be encrypted at rest in a production deployment.
EZBOOST_API_KEY_ENCRYPTION_KEY=base64-encoded-32-byte-key
